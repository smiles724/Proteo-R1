notes/
work/phase0_framing_draft.md
*.bak

# direnv user-local override (optional per-developer customization)
.envrc.local

# Protenix pretrained weights + CCD cache (downloaded by README Installation steps; 7+ GB)
# Ignore weight blobs by extension so small config files (config.json) remain trackable
pretrained/**/*.pt
pretrained/**/*.bin
pretrained/**/*.safetensors
pretrained/**/*.ckpt
pretrained/proteor1_understand/
work/smoke/cdr_hidden/
external/protenix_dev/release_data/ccd_cache/

# Smoke matrix outputs: default-ignore heavy artifacts (PDB, safetensors, Protenix dump);
# whitelist critical small JSON aggregates so cross-task acceptance evidence persists across teardown.
# See .pipeline/memory/40-state/release-prep-todo.md §7 for workflow rationale.
/work/smoke/predictions/
/work/smoke/processed/
/work/smoke/trial_*/predictions/
/work/smoke/trial_*/prepare_cdr/*/protenix_dump/
/work/smoke/trial_*/prepare_cdr/*/cdr_hidden/
/work/smoke/inputs/
/work/smoke/logs/
/work/smoke_matrix/*/trial_*/predictions/
/work/smoke_matrix/*/trial_*/prepare_cdr/*/protenix_dump/
/work/smoke_matrix/*/trial_*/prepare_cdr/*/cdr_hidden/
/work/smoke_matrix/*/trial_*/inputs/
/work/smoke_matrix/*/trial_*/logs/
/work/smoke_matrix/run.log
/work/smoke_matrix/run_retry.log
/work/smoke_matrix/_lead_partial_pos_acc.json
# T-20260511 extended task: same patterns for smoke_matrix_n30/ and smoke_matrix_n30_verifier/
/work/smoke_matrix_n30*/*/trial_*/predictions/
/work/smoke_matrix_n30*/*/trial_*/prepare_cdr/*/protenix_dump/
/work/smoke_matrix_n30*/*/trial_*/prepare_cdr/*/cdr_hidden/
/work/smoke_matrix_n30*/*/trial_*/inputs/
/work/smoke_matrix_n30*/*/trial_*/logs/
/work/smoke_matrix_n30*/run.log
/work/smoke_matrix_n30*/run_retry.log
/work/smoke_matrix_n30*/_lead_partial_pos_acc.json
# Whitelist critical aggregates (re-add after default ignore by extension elsewhere):
!/work/smoke/aar_summary*.json
!/work/smoke/smoke_summary.json
!/work/smoke/preprocessed_summary.json
!/work/smoke/trial_*/aar_summary.json
!/work/smoke/trial_*/smoke_summary.json
!/work/smoke_matrix/cross_entry_pos_acc.json
!/work/smoke_matrix/*/aar_summary*.json
!/work/smoke_matrix/*/smoke_summary.json
!/work/smoke_matrix/*/trial_*/aar_summary.json
!/work/smoke_matrix/*/trial_*/smoke_summary.json
# T-20260511 extended task: same whitelist for smoke_matrix_n30/ + smoke_matrix_n30_verifier/ + new cross_lane_audit.json
!/work/smoke_matrix_n30*/cross_entry_pos_acc.json
!/work/smoke_matrix_n30*/cross_lane_audit.json
!/work/smoke_matrix_n30*/*/aar_summary*.json
!/work/smoke_matrix_n30*/*/smoke_summary.json
!/work/smoke_matrix_n30*/*/trial_*/aar_summary.json
!/work/smoke_matrix_n30*/*/trial_*/smoke_summary.json

